# CiRA Quantum backend — production env template for the NSSM service
# on quantum.cira-core.com (.110). Copy to `.env` at the service
# working directory (default D:\services\cira-quantum\.env) and fill
# in real values. Loaded via python-dotenv on Flask app startup —
# same pattern Oculus uses, so nothing new operator-side.
#
# ⚠️  NEVER COMMIT the populated .env. This template stays in git; the
# real .env stays only on the box.

# ---- Secrets (must set — service will start with the placeholders
# below but auth and BYOK encryption will not be safe until rotated) --

# Flask session signing. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_SECRETS_TOKEN_URLSAFE_64

# Fernet key for BYOK encryption at rest. MUST be a base64-encoded
# 32-byte key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this AFTER users have stored BYOK keys will make their
# stored keys undecryptable — they'll re-enter via Settings.
KEY_ENCRYPTION_SECRET=REPLACE_WITH_FERNET_GENERATE_KEY

# Default admin bootstrap password. Only used on the very first
# init_db() call when the users table is empty. Rotate at first login.
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_BOOTSTRAP_PASSWORD

# ---- Paths (must match what install_quantum_service.ps1 provisions) -

# SQLite database file. Must live outside the git checkout so
# ``git pull`` doesn't touch it and a service reinstall doesn't
# wipe user state.
CIRA_DB_PATH=D:\data\cira-quantum\app.db

# Built Vue SPA. The Flask factory serves index.html at / with SPA
# fallback for any non-/api path when this is set. Left blank in dev
# so Vite's dev server owns the frontend during ``npm run dev``.
CIRA_SPA_DIR=D:\services\cira-quantum\frontend\dist

# ---- Runtime toggles ------------------------------------------------

# Session cookie hardening. Prod behind Cloudflare Tunnel is
# always HTTPS, so this stays on. Flip off only for local dev over
# plain HTTP.
SESSION_COOKIE_SECURE=true

# Stage 1 routing: classify natural-language prompt → hardcoded
# formulator when confident, else fall back to LLM CQM emission.
# On in prod so users of the four canonical templates (Max-Cut,
# Number Partitioning, MIS, Portfolio) get exact-coefficient CQMs.
ENABLE_HARDCODED_ROUTING=1

# Real Origin Quantum QPU submissions (Wukong-C180 / WK_C180_2 /
# HanYuan_01). BYOK model — user brings their own qcloud key, we
# just route the request. Off in dev to avoid accidental submits.
ENABLE_ORIGIN_REAL_HARDWARE=1

# ---- Async queue (optional) -----------------------------------------

# Single-container deploy: leave off, orchestrator uses in-process
# daemon threads. Flip on only when horizontal scaling forces
# multi-worker fan-out via Redis-RQ.
USE_REDIS_QUEUE=0
# REDIS_URL=redis://localhost:6379/0
# QUEUE_NAME=cira-quantum-solves

# ---- Port (must match install_quantum_service.ps1 $port var) --------

# 5209 is deliberately non-adjacent to Oculus's 5008 to prevent
# any port-scan / config-drift collisions on .110.
PORT=5209
