{
  "version": "1",
  "description": "Job-Shop Scheduling, 2 jobs x 2 machines (A,B in fixed order). Durations: J1=(2,1), J2=(1,2). Disjunctive big-M encoding with M=7. Optimum makespan = 4 (J2 first on both machines).",
  "variables": [
    {
      "name": "start_1_A",
      "type": "integer",
      "lower_bound": 0,
      "upper_bound": 5,
      "description": "Start time of job 1 on machine A"
    },
    {
      "name": "start_1_B",
      "type": "integer",
      "lower_bound": 0,
      "upper_bound": 5,
      "description": "Start time of job 1 on machine B"
    },
    {
      "name": "start_2_A",
      "type": "integer",
      "lower_bound": 0,
      "upper_bound": 5,
      "description": "Start time of job 2 on machine A"
    },
    {
      "name": "start_2_B",
      "type": "integer",
      "lower_bound": 0,
      "upper_bound": 5,
      "description": "Start time of job 2 on machine B"
    },
    {
      "name": "y_1_2_A",
      "type": "binary",
      "description": "On machine A, job 1 precedes job 2"
    },
    {
      "name": "y_1_2_B",
      "type": "binary",
      "description": "On machine B, job 1 precedes job 2"
    },
    {
      "name": "makespan",
      "type": "integer",
      "lower_bound": 0,
      "upper_bound": 5,
      "description": "Time at which the last job finishes machine B"
    }
  ],
  "objective": {
    "sense": "minimize",
    "linear": {
      "makespan": 1
    },
    "quadratic": {}
  },
  "constraints": [
    {
      "label": "prec_1_A_B",
      "type": "inequality_ge",
      "linear": {
        "start_1_B": 1,
        "start_1_A": -1
      },
      "quadratic": {},
      "rhs": 2
    },
    {
      "label": "prec_2_A_B",
      "type": "inequality_ge",
      "linear": {
        "start_2_B": 1,
        "start_2_A": -1
      },
      "quadratic": {},
      "rhs": 1
    },
    {
      "label": "nooverlap_1_2_A_a",
      "type": "inequality_le",
      "linear": {
        "start_1_A": 1,
        "start_2_A": -1,
        "y_1_2_A": 7
      },
      "quadratic": {},
      "rhs": 5
    },
    {
      "label": "nooverlap_1_2_A_b",
      "type": "inequality_le",
      "linear": {
        "start_2_A": 1,
        "start_1_A": -1,
        "y_1_2_A": -7
      },
      "quadratic": {},
      "rhs": -1
    },
    {
      "label": "nooverlap_1_2_B_a",
      "type": "inequality_le",
      "linear": {
        "start_1_B": 1,
        "start_2_B": -1,
        "y_1_2_B": 7
      },
      "quadratic": {},
      "rhs": 6
    },
    {
      "label": "nooverlap_1_2_B_b",
      "type": "inequality_le",
      "linear": {
        "start_2_B": 1,
        "start_1_B": -1,
        "y_1_2_B": -7
      },
      "quadratic": {},
      "rhs": -2
    },
    {
      "label": "makespan_1",
      "type": "inequality_ge",
      "linear": {
        "makespan": 1,
        "start_1_B": -1
      },
      "quadratic": {},
      "rhs": 1
    },
    {
      "label": "makespan_2",
      "type": "inequality_ge",
      "linear": {
        "makespan": 1,
        "start_2_B": -1
      },
      "quadratic": {},
      "rhs": 2
    }
  ],
  "test_instance": {
    "description": "Optimum makespan = 4. Run J2 on A at t=0, then J1 on A at t=1; on B, run J2 first (t=1..3) then J1 at t=3..4. Encoding has 7 variables and 8 constraints \u2014 small enough for ExactCQMSolver.",
    "expected_optimum": 4
  }
}