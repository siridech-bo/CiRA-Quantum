{
  "$comment": "Three worked examples used as few-shot turns by every provider. Each entry is one {problem, cqm_json} pair. The CQM JSON values below are taken verbatim from tests/instances/ \u2014 they are already schema-valid under cqm_v1.json. Update both places together if you change a fixture.",
  "examples": [
    {
      "problem": "I have 5 items with weights [2, 3, 4, 5, 9] and values [3, 4, 5, 8, 10]. My knapsack can hold at most 20 units of weight. Which items should I pack to maximize total value?",
      "cqm_json": {
        "version": "1",
        "description": "0/1 Knapsack: 5 items with weights [2, 3, 4, 5, 9] and values [3, 4, 5, 8, 10], capacity 20.",
        "variables": [
          {
            "name": "x_0",
            "type": "binary",
            "description": "Item 0 selected (weight 2, value 3)"
          },
          {
            "name": "x_1",
            "type": "binary",
            "description": "Item 1 selected (weight 3, value 4)"
          },
          {
            "name": "x_2",
            "type": "binary",
            "description": "Item 2 selected (weight 4, value 5)"
          },
          {
            "name": "x_3",
            "type": "binary",
            "description": "Item 3 selected (weight 5, value 8)"
          },
          {
            "name": "x_4",
            "type": "binary",
            "description": "Item 4 selected (weight 9, value 10)"
          }
        ],
        "objective": {
          "sense": "maximize",
          "linear": {
            "x_0": 3,
            "x_1": 4,
            "x_2": 5,
            "x_3": 8,
            "x_4": 10
          },
          "quadratic": {}
        },
        "constraints": [
          {
            "label": "capacity",
            "type": "inequality_le",
            "linear": {
              "x_0": 2,
              "x_1": 3,
              "x_2": 4,
              "x_3": 5,
              "x_4": 9
            },
            "quadratic": {},
            "rhs": 20
          }
        ],
        "test_instance": {
          "description": "Brute-force optimum: pack items {0, 2, 3, 4} for total weight 20, total value 26. (Items 0+1+2+3+4 = weight 23 exceeds capacity.)",
          "expected_optimum": 26
        }
      }
    },
    {
      "problem": "I need to cover four locations {a, b, c, d} using as few service teams as possible. Team S1 covers {a, b}, S2 covers {b, c}, S3 covers {c, d}, S4 covers {a, d}. Which teams should I send?",
      "cqm_json": {
        "version": "1",
        "description": "Set cover: cover universe {a, b, c, d} using minimum sets from S1={a,b}, S2={b,c}, S3={c,d}, S4={a,d}.",
        "variables": [
          {
            "name": "x_1",
            "type": "binary",
            "description": "Set S1 = {a,b} selected"
          },
          {
            "name": "x_2",
            "type": "binary",
            "description": "Set S2 = {b,c} selected"
          },
          {
            "name": "x_3",
            "type": "binary",
            "description": "Set S3 = {c,d} selected"
          },
          {
            "name": "x_4",
            "type": "binary",
            "description": "Set S4 = {a,d} selected"
          }
        ],
        "objective": {
          "sense": "minimize",
          "linear": {
            "x_1": 1,
            "x_2": 1,
            "x_3": 1,
            "x_4": 1
          },
          "quadratic": {}
        },
        "constraints": [
          {
            "label": "cover_a",
            "type": "inequality_ge",
            "linear": {
              "x_1": 1,
              "x_4": 1
            },
            "quadratic": {},
            "rhs": 1
          },
          {
            "label": "cover_b",
            "type": "inequality_ge",
            "linear": {
              "x_1": 1,
              "x_2": 1
            },
            "quadratic": {},
            "rhs": 1
          },
          {
            "label": "cover_c",
            "type": "inequality_ge",
            "linear": {
              "x_2": 1,
              "x_3": 1
            },
            "quadratic": {},
            "rhs": 1
          },
          {
            "label": "cover_d",
            "type": "inequality_ge",
            "linear": {
              "x_3": 1,
              "x_4": 1
            },
            "quadratic": {},
            "rhs": 1
          }
        ],
        "test_instance": {
          "description": "Optimum: select {S1, S3} (or {S2, S4}) for cost 2 \u00e2\u20ac\u201d both partitions cover all four elements with two sets.",
          "expected_optimum": 2
        }
      }
    },
    {
      "problem": "Schedule 2 jobs through 2 machines (A then B). Job 1 takes (2, 1) time units on (A, B); Job 2 takes (1, 2). Each machine processes one job at a time. Find the start times that minimize the makespan.",
      "cqm_json": {
        "version": "1",
        "description": "Job-Shop Scheduling, 2 jobs x 2 machines (A,B in fixed order). Durations: J1=(2,1), J2=(1,2). Disjunctive big-M encoding with M=7. Optimum makespan = 4 (J2 first on both machines).",
        "variables": [
          {
            "name": "start_1_A",
            "type": "integer",
            "lower_bound": 0,
            "upper_bound": 5,
            "description": "Start time of job 1 on machine A"
          },
          {
            "name": "start_1_B",
            "type": "integer",
            "lower_bound": 0,
            "upper_bound": 5,
            "description": "Start time of job 1 on machine B"
          },
          {
            "name": "start_2_A",
            "type": "integer",
            "lower_bound": 0,
            "upper_bound": 5,
            "description": "Start time of job 2 on machine A"
          },
          {
            "name": "start_2_B",
            "type": "integer",
            "lower_bound": 0,
            "upper_bound": 5,
            "description": "Start time of job 2 on machine B"
          },
          {
            "name": "y_1_2_A",
            "type": "binary",
            "description": "On machine A, job 1 precedes job 2"
          },
          {
            "name": "y_1_2_B",
            "type": "binary",
            "description": "On machine B, job 1 precedes job 2"
          },
          {
            "name": "makespan",
            "type": "integer",
            "lower_bound": 0,
            "upper_bound": 5,
            "description": "Time at which the last job finishes machine B"
          }
        ],
        "objective": {
          "sense": "minimize",
          "linear": {
            "makespan": 1
          },
          "quadratic": {}
        },
        "constraints": [
          {
            "label": "prec_1_A_B",
            "type": "inequality_ge",
            "linear": {
              "start_1_B": 1,
              "start_1_A": -1
            },
            "quadratic": {},
            "rhs": 2
          },
          {
            "label": "prec_2_A_B",
            "type": "inequality_ge",
            "linear": {
              "start_2_B": 1,
              "start_2_A": -1
            },
            "quadratic": {},
            "rhs": 1
          },
          {
            "label": "nooverlap_1_2_A_a",
            "type": "inequality_le",
            "linear": {
              "start_1_A": 1,
              "start_2_A": -1,
              "y_1_2_A": 7
            },
            "quadratic": {},
            "rhs": 5
          },
          {
            "label": "nooverlap_1_2_A_b",
            "type": "inequality_le",
            "linear": {
              "start_2_A": 1,
              "start_1_A": -1,
              "y_1_2_A": -7
            },
            "quadratic": {},
            "rhs": -1
          },
          {
            "label": "nooverlap_1_2_B_a",
            "type": "inequality_le",
            "linear": {
              "start_1_B": 1,
              "start_2_B": -1,
              "y_1_2_B": 7
            },
            "quadratic": {},
            "rhs": 6
          },
          {
            "label": "nooverlap_1_2_B_b",
            "type": "inequality_le",
            "linear": {
              "start_2_B": 1,
              "start_1_B": -1,
              "y_1_2_B": -7
            },
            "quadratic": {},
            "rhs": -2
          },
          {
            "label": "makespan_1",
            "type": "inequality_ge",
            "linear": {
              "makespan": 1,
              "start_1_B": -1
            },
            "quadratic": {},
            "rhs": 1
          },
          {
            "label": "makespan_2",
            "type": "inequality_ge",
            "linear": {
              "makespan": 1,
              "start_2_B": -1
            },
            "quadratic": {},
            "rhs": 2
          }
        ],
        "test_instance": {
          "description": "Optimum makespan = 4. Run J2 on A at t=0, then J1 on A at t=1; on B, run J2 first (t=1..3) then J1 at t=3..4. Encoding has 7 variables and 8 constraints \u2014 small enough for ExactCQMSolver.",
          "expected_optimum": 4
        }
      }
    }
  ]
}