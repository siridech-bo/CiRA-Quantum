*.swp
*.swo

# =========================
# OS
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# CiRA Quantum — runtime artifacts
# =========================
# SQLite DB (recreated on first boot; contains user data + encrypted keys)
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm

# Benchmark archive contents (regenerated by `python -m app.benchmarking.run_suite`)
benchmarks/archive/*.json
benchmarks/archive/*.json.gz

# Local logs
*.log

# Secrets — env files are never committed
.env
.env.*
!.env.example

# Misc temp files
tempFileForShare_*
*.tmp

# Claude Code session metadata
.claude/
